// Langchain clean-room schema -> Datomic EAVT mapping
// Generated by deepen_actors.py (ADR 260607 deepening phase).

namespace langchain {

    entity Agent {
        id: string @unique
        name: string
        role: string
        modelRef: string
        status: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Task {
        id: string @unique
        agentId: string
        goal: string
        status: string
        priority: integer
        createdAt: datetime
        updatedAt: datetime
    }

    entity Message {
        id: string @unique
        fromAgentId: string
        toAgentId: string
        performative: string
        content: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Tool {
        id: string @unique
        name: string
        description: string
        schemaRef: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Memory {
        id: string @unique
        agentId: string
        kind: string
        contentRef: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Plan {
        id: string @unique
        taskId: string
        steps: string
        status: string
        createdAt: datetime
        updatedAt: datetime
    }

}

    // Auto-injected Cognitive Schema
    entity CognitiveRecord {
        id: string @unique
        originalPayload: string
        aiStatus: string
        aiInsights: json
        computedAt: datetime
    }
